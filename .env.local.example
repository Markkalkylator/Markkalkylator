# ── CLERK (autentisering) ─────────────────────────────────────────────────────
# Skapa konto på https://clerk.com → skapa app → kopiera nycklar
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutter Clerk skickar till
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/logga-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registrera
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/verktyg
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/verktyg

# ── STRIPE (betalning) ────────────────────────────────────────────────────────
# Skapa konto på https://stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Prisid:n — skapa produkter i Stripe Dashboard → Products → Add product
# Pro: 399 kr/månad, Team: 999 kr/månad
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxxxxxxxxx

# Webhook-hemlighet — Stripe Dashboard → Webhooks → Add endpoint
# Endpoint: https://dindomän.se/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
